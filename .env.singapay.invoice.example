# ==========================================
# SINGAPAY INVOICE PREFIX CONFIGURATION
# ==========================================
# 
# Single prefix configuration for all payment types.
# This prefix will be used for both PDF Pro and Consultation payments.
#
# Add this line to your .env file:

# Single prefix for all payments (default)
SINGAPAY_INVOICE_PREFIX=GRPD

# ==========================================
# HOW IT WORKS
# ==========================================
#
# All transactions will use the same prefix:
# - PDF Pro payments: GRPD202404271234567890
# - Consultation payments: GRPD202404271234567890
#
# Environment examples:
# - Development: SINGAPAY_INVOICE_PREFIX=DEV
# - Staging: SINGAPAY_INVOICE_PREFIX=STG  
# - Production: SINGAPAY_INVOICE_PREFIX=GRPD
#
# ==========================================
# BENEFITS
# ==========================================
#
# ✓ Single consistent branding for all payments
# ✓ Easy identification of your app transactions
# ✓ Simple configuration and management
# ✓ Environment-specific tracking
#
# ==========================================
# NOTES
# ==========================================
#
# • Prefix should be 2-10 characters long
# • Use only uppercase letters and numbers
# • Avoid special characters
# • Changes affect new transactions only
# • Existing transaction codes remain unchanged
