# ============================================================================
# SINGAPAY B2B - PRODUCTION ENV TEMPLATE
# ============================================================================
# IMPORTANT:
# - Do not commit real credentials
# - API key from merchant dashboard is used as SINGAPAY_PARTNER_ID
# - Use production credentials only (not sandbox)

SINGAPAY_MODE=production

# API Credentials
SINGAPAY_PARTNER_ID=REPLACE_WITH_API_KEY
SINGAPAY_CLIENT_ID=REPLACE_WITH_CLIENT_ID
SINGAPAY_CLIENT_SECRET=REPLACE_WITH_CLIENT_SECRET
SINGAPAY_MERCHANT_ACCOUNT_ID=REPLACE_WITH_MERCHANT_ACCOUNT_ID

# API URLs
SINGAPAY_SANDBOX_URL=https://sandbox-payment-b2b.singapay.id
SINGAPAY_PRODUCTION_URL=https://payment-b2b.singapay.id

# Webhook
SINGAPAY_WEBHOOK_ENABLED=true
SINGAPAY_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_HMAC_SECRET
SINGAPAY_WEBHOOK_URL=https://api.your-domain.com/api/webhook/singapay/payment
SINGAPAY_WEBHOOK_SIGNATURE_VALIDATION=true
SINGAPAY_WEBHOOK_IP_WHITELIST=

# Virtual Account + QRIS
SINGAPAY_VA_EXPIRY_HOURS=24
SINGAPAY_VA_KIND=temporary
SINGAPAY_VA_MAX_USAGE=1
SINGAPAY_VA_BANKS=BRI,BNI,DANAMON,MAYBANK
SINGAPAY_VA_DEFAULT_BANK=BRI
SINGAPAY_QRIS_EXPIRY_HOURS=1
SINGAPAY_QRIS_ENABLE_TIP=false

# Cache + Logging
SINGAPAY_CACHE_ENABLED=true
SINGAPAY_CACHE_TTL=3000
SINGAPAY_LOGGING=true
SINGAPAY_LOG_CHANNEL=daily
SINGAPAY_LOG_LEVEL=info

# Timeout + Retry
SINGAPAY_TIMEOUT=30
SINGAPAY_RETRY_MAX_ATTEMPTS=3
SINGAPAY_RETRY_DELAY=1000
